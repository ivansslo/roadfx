# ==========================================================
# ROADFX Development Environment Configuration
# ==========================================================
# Copy this file to .env.dev and start the full stack with:
#   cp .env.dev.example .env.dev
#   make dev
#
# Container-to-container traffic uses Docker Compose service names.
# Browser-facing frontend configuration still targets localhost ports.
# ==========================================================

# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ==========================================================
# Database / Redis (inside Docker Compose)
# ==========================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=roadfx
POSTGRES_USER=roadfx
POSTGRES_PASSWORD=roadfx
DATABASE_URL=postgresql+asyncpg://roadfx:tgo@postgres:5432/roadfx

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ==========================================================
# Host-exposed development ports
# ==========================================================
ROADFXAPI_PORT=8000
ROADFXAI_PORT=8081
ROADFXRAG_PORT=18082
ROADFXPLATFORM_PORT=8003
ROADFXWORKFLOW_PORT=8004
ROADFXPLUGIN_RUNTIME_PORT=8090
ROADFXDEVICE_CONTROL_PORT=8085
ROADFXWEB_PORT=5173
ROADFXWIDGET_PORT=5174

# ==========================================================
# Internal service URLs (container-to-container)
# ==========================================================
API_SERVICE_URL=http://roadfx-api:8000
API_INTERNAL_SERVICE_URL=http://roadfx-api:8001
AI_SERVICE_URL=http://roadfx-ai:8081
RAG_SERVICE_URL=http://roadfx-rag:8082
PLATFORM_SERVICE_URL=http://roadfx-platform:8003
WORKFLOW_SERVICE_URL=http://roadfx-workflow:8000
PLUGIN_RUNTIME_URL=http://roadfx-plugin-runtime:8090
DEVICE_CONTROL_SERVICE_URL=http://roadfx-device-control:8085
WUKONGIM_SERVICE_URL=http://wukongim:5001
WUKONGIM_ENABLED=true
WK_EXTERNAL_IP=127.0.0.1
WK_EXTERNAL_WSADDR=localhost:5200

# ==========================================================
# Frontend browser-side environment variables
# ==========================================================
VITE_API_BASE_URL=http://localhost:8000
VITE_WIDGET_PREVIEW_URL=http://localhost:5174
VITE_WIDGET_SCRIPT_BASE=http://localhost:5174/roadfx-widget-sdk.js
VITE_WIDGET_DEMO_URL=http://localhost:5174/demo.html
VITE_DEBUG_MODE=true

# ==========================================================
# Security
# ==========================================================
SECRET_KEY=dev_secret_key_change_in_production_12345678901234567890
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==========================================================
# Storage / external services
# ==========================================================
STORAGE_TYPE=local
STORE_SERVICE_URL=https://store.roadfx.ai
STORE_WEB_URL=https://store.roadfx.ai
