# Common ports and credentials
POSTGRES_DB=roadfx
POSTGRES_USER=roadfx
POSTGRES_PASSWORD=roadfx
POSTGRES_PORT=5432

ENVIRONMENT=PRODUCTION

# API base URL (for frontend to call backend)
# When using Nginx reverse proxy, use the Nginx URL
VITE_WIDGET_PREVIEW_URL=/widget/
VITE_WIDGET_SCRIPT_BASE=/widget/roadfx-widget-sdk.js
VITE_WIDGET_DEMO_URL=/widget/demo.html
VITE_API_BASE_URL=/api
VITE_DEBUG_MODE=false

# Store
STORE_SERVICE_URL=https://store.roadfx.ai
STORE_WEB_URL=https://store.roadfx.ai

# Redis port
REDIS_PORT=6379


# Service internal ports (not exposed to host, only accessible through Nginx)
# These are used for inter-service communication within Docker network
API_PORT=8000
AI_PORT=8002
PLATFORM_PORT=8003
RAG_PORT=8082
WEB_PORT=3000


# WuKongIM Config
WK_EXTERNAL_IP=
WK_EXTERNAL_TCPADDR=
WK_EXTERNAL_WSADDR=
WK_EXTERNAL_WSSADDR=

# ============================================
# Domain Configuration (Optional)
# ============================================
# Set these to enable domain-based access with Nginx reverse proxy
# Leave empty or commented out to use direct port access

# Domain names for services
WEB_DOMAIN=
WIDGET_DOMAIN=
API_DOMAIN=

# SSL Configuration
# Options: none (no SSL), auto (Let's Encrypt), manual (custom certificates)
SSL_MODE=none

# Let's Encrypt email (required for SSL_MODE=auto)
SSL_EMAIL=

# Enable automatic SSL certificate renewal (for SSL_MODE=auto)
ENABLE_SSL_AUTO_RENEW=true

# Nginx ports (only Nginx is exposed to host)
# All other services (roadfx-api, roadfx-web, roadfx-widget-js) are only accessible through Nginx
NGINX_PORT=80
NGINX_SSL_PORT=443

# nginx file size limit
NGINX_CLIENT_MAX_BODY_SIZE=100m


# ============================================
# Storage Configuration
# ============================================
# STORAGE_TYPE options: local, oss, minio
STORAGE_TYPE=local

# Aliyun OSS Configuration
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_BUCKET_NAME=your-bucket-name
# OSS_BUCKET_URL=https://your-bucket.oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret

# MinIO Configuration
# MINIO_URL=http://your-minio-host:9000
# MINIO_ACCESS_KEY_ID=your-access-key-id
# MINIO_SECRET_ACCESS_KEY=your-secret-access-key
# MINIO_BUCKET_NAME=your-bucket-name
# MINIO_UPLOAD_URL=http://internal-minio:9000
# MINIO_DOWNLOAD_URL=https://public-minio-domain.com


# ============================================
# SMTP Configuration (Optional - for email notifications)
# ============================================
# ROADFXSMTP_HOST=smtp.example.com
# ROADFXSMTP_PORT=587
# ROADFXSMTP_USERNAME=your-username
# ROADFXSMTP_PASSWORD=your-password
# ROADFXSMTP_USE_TLS=true
# ROADFXSMTP_FROM_ADDRESS=noreply@example.com


# ============================================
# Advanced Settings (Optional)
# ============================================
# Token expiration (default: 30 days = 43200 minutes)
# ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Maximum file upload size in MB (default: 20)
# MAX_UPLOAD_SIZE_MB=20

# Log level (default: INFO)
# LOG_LEVEL=INFO


