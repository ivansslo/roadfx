{
  "name": "roadfx-cli",
  "version": "0.1.0",
  "description": "ROADFX CLI - AI Agent customer service operations tool",
  "type": "module",
  "bin": {
    "roadfx": "./bin/roadfx.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
