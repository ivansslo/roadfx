.msg-list {
  height: 100%;
  padding: 16rpx 0;
  box-sizing: border-box;
}

.status-row {
  display: flex;
  justify-content: center;
  padding: 16rpx;
}

.status-text {
  font-size: 24rpx;
  color: #666;
}

.status-text-muted {
  font-size: 24rpx;
  color: #ccc;
}

.msg-row {
  padding: 8rpx 24rpx;
}

.msg-inner {
  display: flex;
  flex-direction: column;
}

.msg-self {
  align-items: flex-end;
}

.msg-agent {
  align-items: flex-start;
}

.msg-image-wrap {
  max-width: 60%;
  border-radius: 16rpx;
  overflow: hidden;
}

.msg-image {
  width: 100%;
  display: block;
}

/* Loading dots animation */
.loading-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #999;
  animation: dotBounce 1.4s infinite ease-in-out both;
}

.dot1 { animation-delay: -0.32s; }
.dot2 { animation-delay: -0.16s; }
.dot3 { animation-delay: 0s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* Streaming cursor */
.cursor {
  display: inline-block;
  width: 4rpx;
  height: 28rpx;
  background: #333;
  margin-left: 4rpx;
  animation: blink 1s step-end infinite;
  vertical-align: text-bottom;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* Error text */
.error-text {
  color: #e74c3c;
  font-size: 26rpx;
}

/* Status */
.msg-status {
  margin-top: 4rpx;
}

.status-text-small {
  font-size: 22rpx;
  color: #999;
}

/* Time label */
.time-label {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 4rpx;
}
